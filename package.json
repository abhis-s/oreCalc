{
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "workbox-window": "^7.4.1"
  },
  "name": "orecalc-frontend",
  "version": "2.0.0",
  "description": "",
  "main": "service-worker.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node scripts/dev/copy-workbox.js && node scripts/fetch-billing-costs.js && concurrently \"pnpm:watch:sass\" \"pnpm:watch:js\" \"pnpm:dev:server\"",
    "watch:sass": "node scripts/dev/watch-sass.js",
    "watch:js": "node scripts/dev/watch-js.js",
    "dev:server": "node -r dotenv/config scripts/dev/start-dev-server.js",
    "build": "VITE_API_BASE_URL=https://api.orecalc.tech pnpm run build:assets",
    "build:dev": "VITE_API_BASE_URL=http://localhost:3000 pnpm run build:assets",
    "build:assets": "node scripts/fetch-billing-costs.js && node scripts/build.js && pnpm run build:css && pnpm run build:sw",
    "build:css": "sass css/main.scss dist/css/main.min.css --style compressed",
    "build:sw": "workbox injectManifest workbox-config.js",
    "bump": "node scripts/bump.js",
    "start": "node scripts/prod/start-prod-server.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "concurrently": "^9.2.1",
    "cpx": "^1.5.0",
    "dotenv": "^17.4.2",
    "live-server": "^1.2.2",
    "replace-in-file": "^8.4.0",
    "sass": "^1.100.0",
    "sharp": "^0.34.5",
    "terser": "5.43.1",
    "workbox-cli": "^7.4.1"
  }
}
