# Frontend configuration
VITE_API_BASE_URL=http://localhost:3000

# SMTP / Email Server configuration (NodeMailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
