# Target Recipient Email Addresses
RECIPIENT_EMAIL_SUPPORT=support@clashcalc.com
RECIPIENT_EMAIL_PRIVACY=privacy@clashcalc.com
RECIPIENT_EMAIL_SECURITY=security@clashcalc.com