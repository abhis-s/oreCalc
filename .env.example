# Frontend configuration
VITE_API_BASE_URL=http://localhost:3000

# SMTP / Email Server configuration (NodeMailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@example.com

# Target Recipient Email Addresses
RECIPIENT_EMAIL_SUPPORT=support@example.com
RECIPIENT_EMAIL_LEGAL=legal@example.com
RECIPIENT_EMAIL_SECURITY=security@example.com

# GCP Billing Export Configuration (for build-time injection)
GCP_BILLING_PROJECT_ID=your-gcp-project-id
GCP_BILLING_DATASET_ID=your_billing_dataset
GCP_BILLING_TABLE_ID=gcp_billing_export_v1_XXXX